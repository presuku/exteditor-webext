{
  "name": "External Editor for WebExtension",
  "description": "Edit text in your favourite external editor!",
  "homepage_url": "https://github.com/presuku/exteditor-webext",
  "manifest_version": 2,
  "version": "0.8",
  "author": "presuku",
  "applications": {
    "gecko": {
      "id": "exteditor.webext@example.com",
      "strict_min_version": "90.0"
    }
  },

  "background": {
    "scripts": ["background.js"]
  },

  "content_scripts": [
      {
          "matches": ["<all_urls>"],
          "js": ["shortcut.js", "content.js"]
      }
  ],

  "options_ui": {
      "page": "options.html"
  },

  "permissions": ["notifications", "nativeMessaging", "storage"]
}
